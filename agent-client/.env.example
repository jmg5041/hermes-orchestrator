AGENT_NAME=clem
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# For Hermes agents (Nous Research) — gateway runs on port 8642
# AGENT_PORT=8642
# AGENT_API_KEY=your-hermes-api-key
# AGENT_MODEL=hermes-agent

# For OpenClaw agents — uses CLI instead of HTTP API
# AGENT_TYPE=openclaw
# OPENCLAW_AGENT_ID=main
# OPENCLAW_BIN=/home/ubuntu/.npm-global/bin/openclaw   (full path if not in PATH)

# Backwards-compatible aliases (still work if you haven't updated your .env)
# HERMES_API_KEY=...
# HERMES_PORT=8642
