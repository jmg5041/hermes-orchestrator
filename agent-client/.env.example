AGENT_NAME=clem
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# For Hermes agents (Nous Research) — gateway runs on port 8642
# AGENT_PORT=8642
# AGENT_API_KEY=your-hermes-api-key
# AGENT_MODEL=hermes-agent

# For OpenClaw agents — gateway runs on port 18789
# AGENT_PORT=18789
# AGENT_API_KEY=your-openclaw-gateway-token
# AGENT_MODEL=your-openclaw-agent-id   (e.g. "jarvis", "ops", "main")

# Backwards-compatible aliases (still work if you haven't updated your .env)
# HERMES_API_KEY=...
# HERMES_PORT=8642
